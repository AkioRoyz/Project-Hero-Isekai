  m_TableData:
  - m_Id: 81790840832
    m_Localized: "\u041F\u0440\u043E\u0431\u043B\u0435\u043C\u0430 \u0441 \u0432\u043E\u043B\u043A\u0430\u043C\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 1219621629952
    m_Localized: "\u0420\u0430\u0437\u0431\u0435\u0440\u0438\u0442\u0435\u0441\u044C
      \u0441 \u0432\u043E\u043B\u043A\u0430\u043C\u0438 \u0432\u043E\u0437\u043B\u0435
      \u0434\u0435\u0440\u0435\u0432\u043D\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 1428724461568
    m_Localized: "\u0421\u0442\u0430\u0440\u043E\u0441\u0442\u0430 \u043F\u0440\u043E\u0441\u0438\u0442
      \u0432\u0430\u0441 \u0441\u043E\u043A\u0440\u0430\u0442\u0438\u0442\u044C \u0447\u0438\u0441\u043B\u043E
      \u0432\u043E\u043B\u043A\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
      \u0441\u0442\u0430\u043B\u0438 \u043D\u0430\u043F\u0430\u0434\u0430\u0442\u044C
      \u043D\u0430 \u043E\u0445\u043E\u0442\u043D\u0438\u043A\u043E\u0432 \u0443
      \u0441\u0435\u0432\u0435\u0440\u043D\u043E\u0433\u043E \u043B\u0435\u0441\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 3101651972096
    m_Localized: "\u0421\u043D\u0430\u0447\u0430\u043B\u0430 \u043D\u0443\u0436\u043D\u043E
      \u0432\u044B\u0441\u043B\u0443\u0448\u0430\u0442\u044C \u0441\u0442\u0430\u0440\u043E\u0441\u0442\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 3246007332864
    m_Localized: "\u041F\u043E\u0433\u043E\u0432\u043E\u0440\u0438\u0442\u0435 \u0441\u043E
      \u0441\u0442\u0430\u0440\u043E\u0441\u0442\u043E\u0439."
    m_Metadata:
      m_Items: []
  - m_Id: 3518540623872
    m_Localized: "\u041F\u043E\u0433\u043E\u0432\u043E\u0440\u0438\u0442\u0435 \u0441\u043E
